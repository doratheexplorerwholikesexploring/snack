<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>霓虹貪吃蛇 | Neon Snake</title>
    <style>
        :root {
            --bg-color: #1a1a2e;
            --grid-color: #16213e;
            --snake-head: #0f3460;
            --snake-body: #4ecca3;
            --food-color: #e94560;
            --text-color: #eeeeee;
            --accent-color: #4ecca3;
        }

        * {
            box-sizing: border-box;
            touch-action: manipulation; /* 防止雙擊縮放 */
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }

        header {
            text-align: center;
            margin-bottom: 10px;
        }

        h1 {
            margin: 0;
            font-size: 2rem;
            text-shadow: 0 0 10px var(--accent-color);
        }

        .score-board {
            display: flex;
            gap: 20px;
            font-size: 1.2rem;
            margin-top: 5px;
        }

        .score-item span {
            font-weight: bold;
            color: var(--accent-color);
        }

        #game-container {
            position: relative;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
            border: 2px solid var(--grid-color);
            background-color: var(--grid-color);
        }

        canvas {
            display: block;
            background-color: var(--grid-color);
        }

        /* 遊戲覆蓋層 (開始、結束、暫停) */
        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(26, 26, 46, 0.85);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
            backdrop-filter: blur(2px);
            transition: opacity 0.3s ease;
        }

        .hidden {
            opacity: 0;
            pointer-events: none;
        }

        .overlay h2 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            color: var(--food-color);
            text-shadow: 0 0 10px var(--food-color);
        }

        .overlay p {
            font-size: 1.1rem;
            margin-bottom: 20px;
            color: #ccc;
        }

        button {
            padding: 12px 30px;
            font-size: 1.2rem;
            background-color: var(--accent-color);
            color: var(--bg-color);
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: bold;
            box-shadow: 0 0 15px var(--accent-color);
            transition: transform 0.1s, box-shadow 0.1s;
        }

        button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 25px var(--accent-color);
        }

        button:active {
            transform: scale(0.95);
        }

        /* 虛擬控制鍵 (針對手機) */
        .controls {
            margin-top: 20px;
            display: grid;
            grid-template-areas: 
                ". up ."
                "left down right";
            gap: 10px;
        }

        .control-btn {
            width: 60px;
            height: 60px;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            user-select: none;
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
        }

        .control-btn:active {
            background: rgba(78, 204, 163, 0.3);
            border-color: var(--accent-color);
        }

        /* 隱藏電腦版不需要的按鍵，但在這裡我們保留以便於觸控螢幕測試 */
        @media (min-width: 768px) {
            .controls {
                display: none; /* 桌面版主要用鍵盤，隱藏虛擬按鍵以保持整潔 */
            }
            .desktop-hint {
                display: block;
                margin-top: 10px;
                color: #666;
                font-size: 0.9rem;
            }
        }
        
        @media (max-width: 767px) {
            .desktop-hint {
                display: none;
            }
        }

    </style>
</head>
<body>

    <header>
        <h1>霓虹貪吃蛇</h1>
        <div class="score-board">
            <div class="score-item">分數: <span id="score">0</span></div>
            <div class="score-item">最高分: <span id="high-score">0</span></div>
        </div>
    </header>

    <main id="game-container">
        <canvas id="gameCanvas" width="400" height="400"></canvas>
        
        <!-- 開始畫面 -->
        <div id="start-screen" class="overlay">
            <h2>貪吃蛇</h2>
            <p>準備好挑戰了嗎？</p>
            <button id="start-btn">開始遊戲</button>
        </div>

        <!-- 遊戲結束畫面 -->
        <div id="game-over-screen" class="overlay hidden">
            <h2>遊戲結束</h2>
            <p>最終分數: <span id="final-score">0</span></p>
            <button id="restart-btn">再玩一次</button>
        </div>

        <!-- 暫停畫面 -->
        <div id="pause-screen" class="overlay hidden">
            <h2>已暫停</h2>
            <button id="resume-btn">繼續遊戲</button>
        </div>
    </main>

    <!-- 虛擬按鍵區 -->
    <div class="controls">
        <div class="control-btn" style="grid-area: up;" data-dir="up">▲</div>
        <div class="control-btn" style="grid-area: left;" data-dir="left">◀</div>
        <div class="control-btn" style="grid-area: down;" data-dir="down">▼</div>
        <div class="control-btn" style="grid-area: right;" data-dir="right">▶</div>
    </div>

    <div class="desktop-hint">使用方向鍵或 WASD 移動，空白鍵暫停</div>

    <script>
        // --- 遊戲配置 ---
        const CANVAS_SIZE = 400;
        const GRID_SIZE = 20; // 每個格子的大小
        const TILE_COUNT = CANVAS_SIZE / GRID_SIZE;
        const GAME_SPEED = 100; // 毫秒/幀 (數字越小越快)

        // --- DOM 元素 ---
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const scoreEl = document.getElementById('score');
        const highScoreEl = document.getElementById('high-score');
        const finalScoreEl = document.getElementById('final-score');
        const startScreen = document.getElementById('start-screen');
        const gameOverScreen = document.getElementById('game-over-screen');
        const pauseScreen = document.getElementById('pause-screen');
        const startBtn = document.getElementById('start-btn');
        const restartBtn = document.getElementById('restart-btn');
        const resumeBtn = document.getElementById('resume-btn');
        const controlBtns = document.querySelectorAll('.control-btn');

        // --- 遊戲狀態變數 ---
        let snake = [];
        let food = { x: 0, y: 0 };
        let dx = 0; // X軸速度
        let dy = 0; // Y軸速度
        let score = 0;
        let highScore = localStorage.getItem('snakeHighScore') || 0;
        let gameInterval;
        let isGameRunning = false;
        let isPaused = false;
        let nextDx = 0; // 緩衝下一幀的方向，防止快速按鍵導致的衝突
        let nextDy = 0;

        // 初始化最高分顯示
        highScoreEl.textContent = highScore;

        // --- 遊戲邏輯 ---

        function initGame() {
            // 初始化蛇的位置 (中間)
            snake = [
                { x: 10, y: 10 },
                { x: 10, y: 11 },
                { x: 10, y: 12 }
            ];
            score = 0;
            scoreEl.textContent = score;
            
            // 初始移動方向 (向上)
            dx = 0;
            dy = -1;
            nextDx = 0;
            nextDy = -1;

            createFood();
            isGameRunning = true;
            isPaused = false;
            
            // 隱藏所有覆蓋層
            startScreen.classList.add('hidden');
            gameOverScreen.classList.add('hidden');
            pauseScreen.classList.add('hidden');

            if (gameInterval) clearInterval(gameInterval);
            gameInterval = setInterval(gameLoop, GAME_SPEED);
        }

        function gameLoop() {
            if (isPaused) return;

            update();
            draw();
        }

        function update() {
            // 更新真實方向
            dx = nextDx;
            dy = nextDy;

            // 計算新的頭部位置
            const head = { x: snake[0].x + dx, y: snake[0].y + dy };

            // 1. 檢查撞牆 (遊戲結束)
            if (head.x < 0 || head.x >= TILE_COUNT || head.y < 0 || head.y >= TILE_COUNT) {
                gameOver();
                return;
            }

            // 2. 檢查撞到自己 (遊戲結束)
            for (let i = 0; i < snake.length; i++) {
                if (head.x === snake[i].x && head.y === snake[i].y) {
                    gameOver();
                    return;
                }
            }

            // 將新頭部加入陣列
            snake.unshift(head);

            // 3. 檢查是否吃到食物
            if (head.x === food.x && head.y === food.y) {
                score += 10;
                scoreEl.textContent = score;
                createFood();
                // 可以在這裡增加難度，例如加速
            } else {
                // 如果沒吃到食物，移除尾部 (維持長度)
                snake.pop();
            }
        }

        function draw() {
            // 清空畫布
            ctx.fillStyle = '#16213e'; // 背景色
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // 畫食物
            ctx.fillStyle = '#e94560';
            ctx.shadowBlur = 15;
            ctx.shadowColor = '#e94560';
            // 畫圓形食物
            ctx.beginPath();
            ctx.arc(
                food.x * GRID_SIZE + GRID_SIZE / 2, 
                food.y * GRID_SIZE + GRID_SIZE / 2, 
                GRID_SIZE / 2 - 2, 
                0, 2 * Math.PI
            );
            ctx.fill();
            
            // 重置陰影，避免影響後續繪圖性能或視覺
            ctx.shadowBlur = 0;

            // 畫蛇
            snake.forEach((segment, index) => {
                // 蛇頭顏色不同
                if (index === 0) {
                    ctx.fillStyle = '#4ecca3'; // 蛇頭亮色
                    ctx.shadowBlur = 10;
                    ctx.shadowColor = '#4ecca3';
                } else {
                    ctx.fillStyle = '#3db38d'; // 蛇身稍暗
                    ctx.shadowBlur = 0;
                }

                // 繪製方塊，留一點間隙
                ctx.fillRect(
                    segment.x * GRID_SIZE + 1, 
                    segment.y * GRID_SIZE + 1, 
                    GRID_SIZE - 2, 
                    GRID_SIZE - 2
                );
            });
            ctx.shadowBlur = 0; // 確保下一幀乾淨
        }

        function createFood() {
            // 隨機生成食物位置，但不能出現在蛇身上
            let validPosition = false;
            while (!validPosition) {
                food.x = Math.floor(Math.random() * TILE_COUNT);
                food.y = Math.floor(Math.random() * TILE_COUNT);

                validPosition = true;
                for (let segment of snake) {
                    if (segment.x === food.x && segment.y === food.y) {
                        validPosition = false;
                        break;
                    }
                }
            }
        }

        function gameOver() {
            isGameRunning = false;
            clearInterval(gameInterval);
            
            // 更新最高分
            if (score > highScore) {
                highScore = score;
                localStorage.setItem('snakeHighScore', highScore);
                highScoreEl.textContent = highScore;
            }

            finalScoreEl.textContent = score;
            gameOverScreen.classList.remove('hidden');
        }

        function togglePause() {
            if (!isGameRunning) return;
            isPaused = !isPaused;
            if (isPaused) {
                pauseScreen.classList.remove('hidden');
            } else {
                pauseScreen.classList.add('hidden');
            }
        }

        // --- 輸入控制 ---

        function changeDirection(direction) {
            if (!isGameRunning || isPaused) return;

            // 防止直接反向移動 (例如正在向上時不能直接向下)
            // 使用 dx/dy 判斷當前實際方向，防止快速按鍵bug
            
            // 如果下一幀的方向已經設置了，要基於下一幀的方向判斷
            const goingUp = nextDy === -1;
            const goingDown = nextDy === 1;
            const goingRight = nextDx === 1;
            const goingLeft = nextDx === -1;

            switch (direction) {
                case 'up':
                    if (!goingDown) { nextDx = 0; nextDy = -1; }
                    break;
                case 'down':
                    if (!goingUp) { nextDx = 0; nextDy = 1; }
                    break;
                case 'left':
                    if (!goingRight) { nextDx = -1; nextDy = 0; }
                    break;
                case 'right':
                    if (!goingLeft) { nextDx = 1; nextDy = 0; }
                    break;
            }
        }

        // 鍵盤監聽
        document.addEventListener('keydown', (e) => {
            // 防止方向鍵滾動頁面
            if(['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', ' '].includes(e.key)) {
                e.preventDefault();
            }

            if (!isGameRunning && startScreen.classList.contains('hidden') === false) {
                if(e.key === 'Enter' || e.key === ' ') initGame();
                return;
            }

            if (e.key === ' ' || e.key === 'Escape') {
                togglePause();
                return;
            }

            switch (e.key) {
                case 'ArrowUp':
                case 'w':
                case 'W':
                    changeDirection('up');
                    break;
                case 'ArrowDown':
                case 's':
                case 'S':
                    changeDirection('down');
                    break;
                case 'ArrowLeft':
                case 'a':
                case 'A':
                    changeDirection('left');
                    break;
                case 'ArrowRight':
                case 'd':
                case 'D':
                    changeDirection('right');
                    break;
            }
        });

        // 虛擬按鍵監聽 (觸控)
        controlBtns.forEach(btn => {
            // 使用 touchstart 以獲得更快的響應，防止點擊延遲
            btn.addEventListener('touchstart', (e) => {
                e.preventDefault(); // 防止預設觸控行為
                const dir = btn.getAttribute('data-dir');
                changeDirection(dir);
            }, { passive: false });

            // 同時也綁定 click 以備不時之需
            btn.addEventListener('click', () => {
                const dir = btn.getAttribute('data-dir');
                changeDirection(dir);
            });
        });

        // 按鈕事件綁定
        startBtn.addEventListener('click', initGame);
        restartBtn.addEventListener('click', initGame);
        resumeBtn.addEventListener('click', togglePause);

        // 初始繪製一次背景
        ctx.fillStyle = '#16213e';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

    </script>
</body>
</html>